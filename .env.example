# Base URL del backend (Spring Boot). Ej: http://localhost:8080
VITE_API_BASE_URL=/api

# Used by Vite dev server proxy (vite.config.ts). It is not bundled into the client.
VITE_DEV_BACKEND_URL=http://localhost:8080

# Duración del examen en minutos (solo UI countdown)
VITE_EXAM_DURATION_MINUTES=30
